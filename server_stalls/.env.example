DATABASE_URL=postgresql://postgres:password@localhost:5432/AgileSMU
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=password
PGDATABASE=AgileSMU
PGSSL=false
PORT=4002

# WebSocket for admin stall notifications (same port as HTTP):
# ws://localhost:4002/ws/admin?token=<JWT>

# Must match server_accounts JWT_SECRET (admin routes verify the same login token)
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# AWS S3 (required for stall photo + proof uploads)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-southeast-2
S3_BUCKET=your-bucket-name

# Presigned read URLs for private photos (default: on). Set false if bucket photos are public.
# S3_USE_PRESIGNED_URLS=false
# S3_SIGNED_URL_EXPIRES_SECONDS=86400

# Optional: upload photos as public-read (only if your bucket allows ACLs)
# S3_PHOTOS_PUBLIC=true

# AWS S3 (required for stall photo + proof uploads)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-southeast-1
S3_BUCKET=your-bucket-name

# Optional: temporary credentials (STS / assumed role)
# AWS_SESSION_TOKEN=

# Optional: custom public URL base (CloudFront or custom domain)
# S3_PUBLIC_BASE_URL=https://cdn.example.com

# Optional: S3-compatible storage (MinIO, LocalStack)
# S3_ENDPOINT=http://localhost:9000
# S3_FORCE_PATH_STYLE=true

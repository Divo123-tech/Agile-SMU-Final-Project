# Used when running: npm run build (production mode)
# GitHub Actions deploy sets these automatically.

# Must match repo name for project Pages URL:
# https://<user>.github.io/Agile-SMU-Final-Project/
VITE_BASE_PATH=/Agile-SMU-Final-Project/

# Public URL of your deployed API gateway (HTTPS). Set as repo variable in GitHub:
# Settings → Secrets and variables → Actions → Variables → VITE_API_URL
VITE_API_URL=https://your-gateway.example.com
